{
  "info": {
    "name": "Compra y Venta — Microservicios (vía API Gateway)",
    "description": "Colección de la arquitectura de microservicios. Todas las requests van al API Gateway (:8080), que enruta a cada servicio y bloquea /interno/*.\n\nSetup: 1) `docker compose --profile microservices up`  2) Correr '00 - Auth / Login Firebase' para obtener el token (se guarda solo en {{token}}).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "firebase_api_key", "value": "" },
    { "key": "token", "value": "" },
    { "key": "saga_id", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "00 - Auth",
      "item": [
        {
          "name": "Login Firebase (guarda {{token}})",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.idToken) { pm.collectionVariables.set('token', data.idToken); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebase_api_key}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"pass123\",\n  \"returnSecureToken\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "01 - Identidad y Acceso",
      "item": [
        { "name": "Listar personas", "request": { "method": "GET", "url": "{{base_url}}/personas" } },
        {
          "name": "Crear persona",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/personas",
            "body": { "mode": "raw", "raw": "{\n  \"nombre_completo\": \"Juan Pérez\",\n  \"documento_identidad\": \"30111222\",\n  \"telefono\": \"1155667788\",\n  \"fecha_nacimiento\": \"1995-05-10\"\n}" }
          }
        },
        {
          "name": "Crear usuario de persona",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/personas/:persona_id/usuarios",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"juan@test.com\",\n  \"firebase_uid\": \"<uid-de-firebase>\"\n}" }
          }
        },
        {
          "name": "Crear dirección de persona",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/personas/:persona_id/direcciones",
            "body": { "mode": "raw", "raw": "{\n  \"calle\": \"Av. Corrientes\",\n  \"numero\": \"1234\",\n  \"ciudad\": \"Buenos Aires\",\n  \"provincia\": \"CABA\",\n  \"descripcion\": \"Local\"\n}" }
          }
        }
      ]
    },
    {
      "name": "02 - Billetera",
      "item": [
        { "name": "Ver billetera", "request": { "method": "GET", "url": "{{base_url}}/billetera" } },
        {
          "name": "Cargar saldo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/billetera/cargar",
            "body": { "mode": "raw", "raw": "{\n  \"monto\": 50000\n}" }
          }
        },
        { "name": "Historial", "request": { "method": "GET", "url": "{{base_url}}/billetera/historial" } }
      ]
    },
    {
      "name": "03 - Catálogo",
      "item": [
        { "name": "Listar productos", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/productos" } },
        { "name": "Listar categorías", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/productos/categorias" } },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/productos",
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Notebook Lenovo\",\n  \"descripcion\": \"16GB RAM\",\n  \"precio\": 1500.0,\n  \"categoria_id\": \"<uuid-categoria>\",\n  \"stock\": 10,\n  \"sku\": \"NB-LEN-001\",\n  \"imagenes\": [\"img1.jpg\"],\n  \"direccion_punto_venta_id\": \"<uuid-direccion-del-vendedor>\"\n}" }
          }
        },
        {
          "name": "Búsqueda",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/busqueda?q=notebook&precio_min=100&orden=precio&ascendente=true",
              "host": ["{{base_url}}"],
              "path": ["busqueda"],
              "query": [
                { "key": "q", "value": "notebook" },
                { "key": "precio_min", "value": "100" },
                { "key": "orden", "value": "precio" },
                { "key": "ascendente", "value": "true" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "04 - Carrito & Checkout (saga)",
      "item": [
        { "name": "Ver carrito", "request": { "method": "GET", "url": "{{base_url}}/carrito" } },
        {
          "name": "Agregar item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/carrito/items",
            "body": { "mode": "raw", "raw": "{\n  \"producto_id\": \"<uuid-producto>\",\n  \"cantidad\": 1\n}" }
          }
        },
        {
          "name": "Aplicar descuento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/carrito/descuento",
            "body": { "mode": "raw", "raw": "{\n  \"codigo\": \"PROMO20\"\n}" }
          }
        },
        {
          "name": "Checkout (dispara la CheckoutSaga; guarda {{saga_id}})",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.saga_id) { pm.collectionVariables.set('saga_id', data.saga_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/carrito/checkout",
            "body": { "mode": "raw", "raw": "{\n  \"direccion_entrega\": \"Av. Siempre Viva 742, CABA\"\n}" }
          }
        },
        { "name": "Estado de la saga (delivery async)", "request": { "method": "GET", "url": "{{base_url}}/carrito/checkout/{{saga_id}}" } }
      ]
    },
    {
      "name": "05 - Delivery",
      "item": [
        { "name": "Pendientes", "request": { "method": "GET", "url": "{{base_url}}/deliveries" } },
        { "name": "Mis asignados", "request": { "method": "GET", "url": "{{base_url}}/deliveries/mis-asignados" } },
        { "name": "Tomar delivery", "request": { "method": "POST", "url": "{{base_url}}/deliveries/:delivery_id/tomar" } },
        { "name": "Entregar", "request": { "method": "POST", "url": "{{base_url}}/deliveries/:delivery_id/entregar" } }
      ]
    },
    {
      "name": "06 - Gateway",
      "item": [
        { "name": "Health", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/health" } },
        {
          "name": "Interno bloqueado (espera 403)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/interno/stock/reservar"
          }
        }
      ]
    }
  ]
}
