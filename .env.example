DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/compra_venta_db

# Firebase — descargar desde Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase web config — Firebase Console > Project Settings > General > Your apps > Web app
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=

# Encriptación de datos sensibles en BD
# Generar con: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# Billetera virtual
BILLETERA_LIMITE_CARGA=100000
BILLETERA_MONEDA=ARS
