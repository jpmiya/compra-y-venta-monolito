DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/compra_venta_db

# Firebase — descargar desde Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase web config — Firebase Console > Project Settings > General > Your apps > Web app
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
